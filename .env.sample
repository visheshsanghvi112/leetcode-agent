# For GitHub Actions, you do NOT need this file in your repository!
# You simply paste the raw JSON text from your `leetcode_session.json` 
# DIRECTLY into the GitHub Secret box on the website.
# 
# However, if you ever needed to replicate the GitHub Secret in a local .env file, 
# it would look exactly like this:

LEETCODE_SESSION_JSON='{
  "cookies": [
    {
      "name": "LEETCODE_SESSION",
      "value": "your_actual_session_value_here",
      "domain": ".leetcode.com",
      "path": "/",
      "httpOnly": true,
      "secure": true,
      "sameSite": "Lax"
    },
    {
      "name": "csrftoken",
      "value": "your_actual_csrf_token_here",
      "domain": ".leetcode.com",
      "path": "/",
      "httpOnly": false,
      "secure": true,
      "sameSite": "Lax"
    }
  ],
  "origins": []
}'
